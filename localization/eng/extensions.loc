  "CARD_EDITOR.tooltip.countResultEffect": "Which effect row's actual result should drive this scaling, repeat, or condition. This Effect enables Echoing Slash-style damage loops.",
  "CARD_EDITOR.tooltip.countResultMetric": "Which actual result to read: kills, HP damage, blocked damage, total damage, overkill, or instances.",
  "CARD_EDITOR.tooltip.countdownEffectRows": "Pick extra effect rows to run when this countdown expires.",
  "CARD_EDITOR.tooltip.creatureCommand": "Choose which non-power creature state or command to apply.",
  "CARD_EDITOR.tooltip.customRewardPools": "When enabled, this created card can be injected into selected vanilla event reward pools.",
  "CARD_EDITOR.tooltip.delayedPileAction": "Action to perform after the selected cards have reached this effect's amount as their counter threshold.",
  "CARD_EDITOR.tooltip.delayedPileCounterScope": "Combat counters reset each combat. Run counters are saved per deck card and keep counting across combats.",
  "CARD_EDITOR.tooltip.delayedPileCounterUnit": "Text label for the counter. The trigger row decides when this counter actually advances.",
  "CARD_EDITOR.tooltip.durationTickPolicy": "Controls whether the applied power/status skips its next duration tick. Suppress Next Tick only applies when this creates a new power, matching vanilla Doubt/Shame-style end-turn debuffs.",
  "CARD_EDITOR.tooltip.effectLimitRow": "Pick one effect row to receive this use limit. Add another Effect Limit row for another target.",
  "CARD_EDITOR.tooltip.hoverPreviewCard": "Pick the card that should be shown as an extra preview when this card is hovered. This does not create or play that card.",
  "CARD_EDITOR.tooltip.passiveBehaviorCondition": "Optionally require a condition for this passive editor rule.",
  "CARD_EDITOR.tooltip.pickRewardPools": "Open the vanilla event reward-pool picker.",
  "CARD_EDITOR.tooltip.potionDuplicates": "Allow the same potion to be rolled more than once when creating multiple potions.",
  "CARD_EDITOR.tooltip.potionInCombatOnly": "Only use potions that vanilla allows random combat generation to create.",
  "CARD_EDITOR.tooltip.potionMode": "Random uses the pool and rarity filters. Specific creates the exact potion id selected below.",
  "CARD_EDITOR.tooltip.potionPool": "Random potion source pool. Vanilla Pool matches Alchemize: your character pool plus the shared pool.",
  "CARD_EDITOR.tooltip.potionRarity": "Random potion rarity. Any Rarity keeps vanilla rarity weighting when possible.",
  "CARD_EDITOR.tooltip.powerStackMode": "Merge matching power effects into one stacked entry, or keep each application as a separate power entry.",
  "CARD_EDITOR.tooltip.rewardBucket": "Controls which vanilla rarity bucket this card counts as when an event reward is rarity-filtered.",
  "CARD_EDITOR.tooltip.rewardInjection": "Controls how aggressively this card is inserted when a selected vanilla reward pool appears.",
  "CARD_EDITOR.tooltip.scalingBaseAmount": "Per-count bonus amount. Leave unchanged to mirror the core amount; edit it to make the base action and scaling bonus different.",
  "CARD_EDITOR.tooltip.scalingCountStep": "How many counted units make one scaling step. Example: Per Count 10 with Block Lost means 10 Block lost = 1 step, 20 = 2 steps. Threshold still checks the raw count.",
  "CARD_EDITOR.tooltip.scalingRepeatExtraTimes": "How many additional repeats this effect gains for each scaling step.",
  "CARD_EDITOR.tooltip.specificCardUpgrade": "For transform effects: choose whether the replacement card matches the source card's upgrade level, is base, or is upgraded once.",
  "CARD_EDITOR.tooltip.specificPotionId": "Exact potion model id. Use Pick to select from the game's potion database.",
  "CARD_EDITOR.tooltip.statefulTransformCard": "Pick the card this card should transform into when Transform Match passes. Return Match can transform it back under a separate condition.",
  "CARD_EDITOR.tooltip.statefulTransformCondition": "Use Count Logic to require history or pile matches before transforming.",
  "CARD_EDITOR.tooltip.statefulTransformDuration": "How long the transformed state lasts.",
  "CARD_EDITOR.tooltip.statefulTransformDurationAmount": "How many turns or combats the transformed state lasts.",
  "CARD_EDITOR.tooltip.statefulTransformMode": "Transform once, or toggle back and forth when the transformed card runs this effect again.",
